# ── Required ───────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID. Start the bot, send /chatid, paste the number here, restart.
ALLOWED_CHAT_ID=

# ── Config directory ───────────────────────────────────────────────────────────
# Personal config files (CLAUDE.md, agent configs) live here, outside the repo.
# Defaults to ~/.claudeclaw if not set.
# CLAUDECLAW_CONFIG=~/.claudeclaw

# ── Claude Auth (optional) ─────────────────────────────────────────────────────
# ClaudeClaw uses your existing Claude Code auth (claude login) by default.
# Set ANTHROPIC_API_KEY to use pay-per-token billing instead — recommended for
# always-on or server deployments.
ANTHROPIC_API_KEY=

# CLAUDE_CODE_OAUTH_TOKEN=   # Override which Claude account is used

# ── Voice ──────────────────────────────────────────────────────────────────────
# Groq — free tier, for voice transcription (Whisper)
# Get at: https://console.groq.com
GROQ_API_KEY=

# whisper-cpp — local STT fallback (no API key, runs on-device)
# Install: brew install whisper-cpp
# Download model: whisper-cpp --download-model small
# WHISPER_CPP_PATH=whisper-cpp
# WHISPER_MODEL_PATH=/opt/homebrew/share/whisper-cpp/models/ggml-small.bin

# ElevenLabs — primary TTS provider (clone your own voice)
# Get at: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Gradium AI — alternative TTS provider
# Get at: https://gradium.ai (free tier: 45k credits/month)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# Kokoro - local OpenAI-compatible TTS (Docker). Zero cost, works offline.
# Any server implementing the OpenAI /v1/audio/speech API works here.
# Setup: docker run -d --name kokoro-tts -p 8880:8880 ghcr.io/remsky/kokoro-fastapi
# KOKORO_URL=http://localhost:8880
# KOKORO_VOICE=af_heart
# KOKORO_MODEL=kokoro

# Local TTS fallback (macOS only, requires ffmpeg)
# Voice name from: say -v '?'
# TTS_VOICE=Thomas

# ── Integrations ───────────────────────────────────────────────────────────────
# Google AI Studio key — for video analysis via the gemini-api-dev skill
# Get at: https://aistudio.google.com
GOOGLE_API_KEY=

# WhatsApp bridge (requires running scripts/wa-daemon.ts separately)
# WHATSAPP_ENABLED=true

# ── Slack ──────────────────────────────────────────────────────────────────────
# Slack User OAuth Token — see README for step-by-step setup
# Starts with xoxp-
SLACK_USER_TOKEN=

# ── Cost / Rate Warnings (off by default) ─────────────────────────────────────
# Only useful if you're on pay-per-use API billing. Subscription users leave off.
# Set a dollar amount to enable daily cost warnings at 80% + 95% thresholds.
# DAILY_COST_BUDGET=10.00
# Set a token count to enable hourly token warnings at 80% + 95% thresholds.
# HOURLY_TOKEN_BUDGET=500000

# ── Agent Limits ──────────────────────────────────────────────────────────────
# Max time (ms) a single agent query can run before auto-abort.
# Prevents runaway commands from blocking the bot indefinitely. Default: 300000 (5 min).
# AGENT_TIMEOUT_MS=300000

# Context window size for your Claude model. Default: 1000000 (1M for Opus/Sonnet).
# CONTEXT_LIMIT=1000000

# Streaming strategy for real-time token output. Default: off.
# Options: global-throttle (stream to Telegram), single-agent-only, off
# STREAM_STRATEGY=off

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Web dashboard for monitoring memories, tokens, tasks, and health.
# Generate a token: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DASHBOARD_TOKEN=
# DASHBOARD_PORT=3141
# DASHBOARD_URL=               # Set to your Cloudflare Tunnel URL for remote access

# ── Database Encryption ────────────────────────────────────────────────────────
# SQLCipher encryption key. Auto-generated on first run if not set.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=

# ── Security ──────────────────────────────────────────────────────────────────
# PIN lock: bot starts locked and requires this PIN to accept commands.
# The setup wizard generates this automatically. Format: "salt:hash".
# Generate manually: node -e "const c=require('crypto'),s=c.randomBytes(16).toString('hex');console.log(s+':'+c.createHash('sha256').update(s+'YOUR_PIN').digest('hex'))"
# SECURITY_PIN_HASH=

# Auto-lock after N minutes of inactivity. Only works when PIN is set. 0 = disabled.
# IDLE_LOCK_MINUTES=30

# Emergency kill phrase. Sending this immediately stops ALL agents and exits.
# Choose something unique you won't accidentally type, or let the setup wizard generate one.
# EMERGENCY_KILL_PHRASE=

# ── OAuth Health Monitoring (OPT-IN) ─────────────────────────────────────────
# Alerts via Telegram before the Claude CLI OAuth token expires. Useful for
# daemon deployments (launchd/systemd) where token expiry causes silent
# failures AND you're within arm's reach of your machine to re-auth.
#
# OFF by default because fresh installs were getting spammed with "expiring
# soon" alerts, and users who can't easily re-auth on demand just end up
# ignoring the messages. Set to true only if you want the nudges.
# OAUTH_HEALTH_ENABLED=true
# OAUTH_CHECK_MINUTES=30
# OAUTH_ALERT_HOURS=2

# ── Google OAuth (for Gmail + Calendar skills) ─────────────────────────────────
# Paths to OAuth credentials and tokens. The Python scripts (gmail.py, gcal.py)
# read these via the CLAUDECLAW_DIR env var. Only change if you store them elsewhere.
GOOGLE_CREDS_PATH=~/.config/gmail/credentials.json
GMAIL_TOKEN_PATH=~/.config/gmail/token.json
GCAL_TOKEN_PATH=~/.config/calendar/token.json

# ── War Room (voice boardroom) ────────────────────────────────────────────────
# Enable the War Room voice feature on the dashboard.
# Requires GOOGLE_API_KEY above for live mode (Gemini Live speech-to-speech).
# WARROOM_ENABLED=true
# WARROOM_PORT=7860
# WARROOM_MODE=live              # "live" (default, Gemini native audio) or "legacy" (Deepgram+Cartesia)
# WARROOM_LIVE_MODEL=            # Optional Gemini model override
# WARROOM_LIVE_VOICE=            # Optional Gemini voice override (e.g. "Charon")
#
# Legacy mode only (if WARROOM_MODE=legacy):
# DEEPGRAM_API_KEY=
# CARTESIA_API_KEY=
#
# War Room Python venv setup (one-time):
#   python3 -m venv warroom/.venv
#   source warroom/.venv/bin/activate
#   pip install -r warroom/requirements.txt

# ── Pika Developer Key (for the pikastream-video-meeting skill) ────────────────
# Get one at https://www.pika.me/dev/. Used by the meet-cli wrapper to join
# Google Meet / Zoom calls as an AI avatar. Each agent resolves its avatar
# from warroom/avatars/<agent>.png and its voice_id from agent.yaml
# (meet_voice_id field). Billing is per-minute, ~$0.275/min.
# PIKA_DEV_KEY=dk_your-developer-key-here

# ── Recall.ai (for voice-only meeting bot) ─────────────────────────────────────
# Sign up at https://recall.ai and create an API key. Used by the voice-only
# path in meet-cli join-voice: bot joins a Google Meet / Zoom / Teams call as
# an audio-only participant and routes audio through Deepgram STT → Claude →
# Cartesia TTS so the agent can run tool calls mid-meeting. The region matches
# whichever datacenter your account was provisioned in (us-east-1, us-west-2,
# eu-central-1, or ap-northeast-1).
# RECALL_API_KEY=your-recall-api-key
# RECALL_REGION=us-west-2
